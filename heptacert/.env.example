# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=heptacert
POSTGRES_USER=heptacert
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

DATABASE_URL=postgresql+asyncpg://heptacert:CHANGE_ME_STRONG_PASSWORD@db:5432/heptacert
ALEMBIC_DATABASE_URL=postgresql+psycopg://heptacert:CHANGE_ME_STRONG_PASSWORD@db:5432/heptacert

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS
JWT_EXPIRES_MINUTES=1440

BOOTSTRAP_SUPERADMIN_EMAIL=superadmin@heptapusgroup.com
BOOTSTRAP_SUPERADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── URLs (production) ────────────────────────────────────────────────────────
PUBLIC_BASE_URL=https://cert.heptapusgroup.com
FRONTEND_BASE_URL=https://cert.heptapusgroup.com
NEXT_PUBLIC_API_BASE=https://cert.heptapusgroup.com/api
CORS_ORIGINS=https://cert.heptapusgroup.com

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_MODE=local
LOCAL_STORAGE_DIR=/data

# ── Email (Mailcow SMTP) ─────────────────────────────────────────────────────
EMAIL_TOKEN_SECRET=CHANGE_ME_RANDOM_64_CHARS
SMTP_HOST=mail.heptapusgroup.com
SMTP_PORT=587
SMTP_USER=noreply@heptapusgroup.com
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM="HeptaCert <noreply@heptapusgroup.com>"

# ── Payments ──────────────────────────────────────────────────────────────────
PAYMENT_ENABLED=false
ACTIVE_PAYMENT_PROVIDER=iyzico

IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://api.iyzipay.com

PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
