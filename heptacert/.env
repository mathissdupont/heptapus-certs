POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

DATABASE_URL=

JWT_SECRET=change-me-super-long-random
JWT_EXPIRES_MINUTES=1440

BOOTSTRAP_SUPERADMIN_EMAIL=
BOOTSTRAP_SUPERADMIN_PASSWORD=

PUBLIC_BASE_URL=http://localhost:8765
CORS_ORIGINS=*
STORAGE_MODE=local
LOCAL_STORAGE_DIR=/data

# Email (Mailcow SMTP)
EMAIL_TOKEN_SECRET=generate-a-long-random-secret-here
SMTP_HOST=mail.yourmailcowdomain.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASSWORD=your-mailcow-smtp-password
SMTP_FROM="HeptaCert <noreply@heptapus.com>"

# Payments (set PAYMENT_ENABLED=true when vergi levhası is ready)
PAYMENT_ENABLED=false
ACTIVE_PAYMENT_PROVIDER=iyzico

# iyzico (sandbox by default)
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# PayTR
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
